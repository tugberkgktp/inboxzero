# ── InboxZero environment variables ───────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit a real .env (it is gitignored).

# --- Database (Postgres) ---
# In docker-compose these are wired automatically to the `postgres` service.
# For LOCAL (non-docker) dev against the dockerized DB, use localhost:
DATABASE_URL=postgresql://inboxzero:inboxzero@localhost:5432/inboxzero

# --- Queue broker (Redis) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
# Use a long random string in production.
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# --- AI provider (Groq) ---
# OPTIONAL: if blank, the worker uses a deterministic stub (no key needed).
# Get a free key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Worker tuning ---
WORKER_CONCURRENCY=3
JOB_ATTEMPTS=3
JOB_BACKOFF_MS=1000

# Proactive AI rate limit (keep under your provider's free-tier limit).
# Groq free tier is ~30 requests/min; 20/60s leaves headroom.
AI_RATE_MAX=20
AI_RATE_DURATION_MS=60000

# Input guards
MAX_BATCH_ITEMS=50
MAX_ITEM_CHARS=4000

# --- API ---
PORT=4000
# Comma-separated allowed origins for the deployed frontend; * for dev.
CORS_ORIGIN=*
